{
  "version": 1,
  "drivers": [
    {
      "driver": "openai_compatible",
      "endpoints": [
        {
          "id": "groq",
          "config": {
            "api_base": "https://api.groq.com/openai/v1",
            "api_key": "REPLACE_ME"
          }
        },
        {
          "id": "openrouter",
          "config": {
            "api_base": "https://openrouter.ai/api/v1",
            "api_key": "REPLACE_ME"
          }
        }
      ]
    }
  ],
  "vocabulary": {
    "en": ["Kubernetes", "Goroutine", "Anthropic", "Tailscale"],
    "ru": ["Санкт-Петербург"]
  },
  "replacements": {
    "en": {
      "new line": "\n",
      "new paragraph": "\n\n"
    }
  },
  "hotkeys": {
    "ctrl+alt+space": {
      "mode": "hold",
      "transcribe": { "model": "groq:whisper-large-v3", "input_language": "en" }
    },
    "ctrl+alt+d": {
      "mode": "toggle",
      "transcribe": { "model": "groq:whisper-large-v3" }
    },
    "ctrl+alt+r": {
      "mode": "hold",
      "transcribe": { "model": "groq:whisper-large-v3", "output_language": "en" }
    },
    "ctrl+alt+f": {
      "mode": "hold",
      "transcribe": { "model": "groq:whisper-large-v3" },
      "translate": {
        "output_language": "fr",
        "model": "openrouter:openai/gpt-4o-mini",
        "prompt": "Use formal register. This is technical content about software architecture."
      }
    },
    "ctrl+alt+e": {
      "mode": "hold",
      "transcribe": { "model": "groq:whisper-large-v3" },
      "enhance": {
        "prompt": "Format as a professional email with an appropriate greeting and sign-off.",
        "model": "openrouter:anthropic/claude-3.5-haiku"
      }
    }
  },
  "toggle_max_seconds": 60,
  "injection_mode": "paste",
  "sound_feedback": true,
  "log_level": "info"
}
