{
  "version": 1,
  "drivers": [
    {
      "driver": "openai_compatible",
      "endpoints": [
        {
          "id": "openai",
          "config": {
            "api_base": "https://api.openai.com/v1",
            "api_key": "REPLACE_ME"
          }
        }
      ]
    }
  ],
  "vocabulary": {
    "en": ["Kubernetes", "Goroutine", "Anthropic", "Tailscale"]
  },
  "replacements": {
    "en": {
      "new line": "\n",
      "new paragraph": "\n\n"
    }
  },
  "hotkeys": {
    "option+left": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": ""
      }
    },
    "option+down": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": ""
      },
      "enhance": {
        "prompt": "",
        "model": "openai:gpt-5.4-nano"
      }
    },
    "option+right": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": ""
      },
      "translate": {
        "output_language": "en",
        "model": "openai:gpt-5.4-nano",
        "prompt": ""
      },
      "enhance": {
        "prompt": "",
        "model": "openai:gpt-5.4-nano"
      }
    }
  },
  "toggle_max_seconds": 60,
  "injection_mode": "paste",
  "sound_feedback": true,
  "log_level": "info"
}
