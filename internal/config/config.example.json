{
  "version": 1,
  "drivers": [
    {
      "driver": "openai_compatible",
      "endpoints": [
        {
          "id": "openai",
          "config": {
            "api_base": "https://api.openai.com/v1",
            "api_key": "REPLACE_ME"
          }
        }
      ]
    }
  ],
  "vocabulary": {
    "en": ["Kubernetes", "Goroutine", "Anthropic", "Tailscale"]
  },
  "replacements": {
    "en": {
      "new line": "\n",
      "new paragraph": "\n\n"
    }
  },
  "hotkeys": {
    "ctrl+alt+space": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "input_language": "en"
      }
    },
    "ctrl+alt+d": {
      "mode": "toggle",
      "transcribe": { "model": "openai:whisper-1" }
    },
    "ctrl+alt+r": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": "en"
      }
    },
    "ctrl+alt+f": {
      "mode": "hold",
      "transcribe": { "model": "openai:whisper-1" },
      "translate": {
        "output_language": "fr",
        "model": "openai:gpt-5.4-nano"
      }
    },
    "ctrl+alt+t": {
      "mode": "hold",
      "transcribe": { "model": "openai:whisper-1" },
      "translate": {
        "output_language": "fr",
        "model": "openai:gpt-5.4-nano",
        "prompt": "Use formal register. This is technical content about software architecture."
      }
    },
    "ctrl+alt+c": {
      "mode": "hold",
      "transcribe": { "model": "openai:whisper-1" },
      "enhance": {
        "model": "openai:gpt-5.4-nano"
      }
    },
    "ctrl+alt+e": {
      "mode": "hold",
      "transcribe": { "model": "openai:whisper-1" },
      "enhance": {
        "prompt": "Format as a professional email with an appropriate greeting and sign-off.",
        "model": "openai:gpt-5.4-nano"
      }
    }
  },
  "toggle_max_seconds": 60,
  "injection_mode": "paste",
  "sound_feedback": true,
  "log_level": "info"
}
