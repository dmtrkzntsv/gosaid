{
  "version": 2,
  "drivers": [
    {
      "driver": "openai_compatible",
      "endpoints": [
        {
          "id": "openai",
          "config": {
            "api_base": "https://api.openai.com/v1",
            "api_key": "REPLACE_ME"
          }
        }
      ]
    }
  ],
  "hotkeys": {
    "option+left": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": ""
      }
    },
    "option+down": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": ""
      },
      "enhance": {
        "model": "openai:gpt-5.4-nano"
      }
    },
    "option+right": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": ""
      },
      "enhance": {
        "model": "openai:gpt-5.4-nano"
      },
      "translate": {
        "output_language": "en",
        "model": "openai:gpt-5.4-nano"
      }
    },
    "option+up": {
      "mode": "hold",
      "transcribe": {
        "model": "openai:whisper-1",
        "output_language": ""
      },
      "compose": {
        "enable": true,
        "model": "openai:gpt-5.4-nano",
        "instructions": "Write in a formal, business-email register."
      }
    }
  },
  "toggle_max_seconds": 60,
  "injection_mode": "paste",
  "sound_feedback": true,
  "log_level": "err",
  "user_context": ""
}
